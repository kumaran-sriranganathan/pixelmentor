# PixelMentor Backend — Local Development Environment
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# App
ENVIRONMENT=dev

# Azure OpenAI (get from Azure Portal → your OpenAI resource → Keys and Endpoint)
AZURE_OPENAI_ENDPOINT=https://YOUR-OPENAI-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key-here
AZURE_OPENAI_API_VERSION=2025-01-01

# Azure AI Vision (get from Azure Portal → your Vision resource)
AZURE_VISION_ENDPOINT=https://YOUR-VISION-RESOURCE.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-vision-key-here

# Cosmos DB (get from Azure Portal → your Cosmos DB → Keys)
COSMOS_ENDPOINT=https://YOUR-COSMOS.documents.azure.com:443/
COSMOS_CONNECTION_STRING=AccountEndpoint=https://...

# Azure Blob Storage
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
STORAGE_ACCOUNT_NAME=your-storage-account-name

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key

# Azure AD (for token validation — leave blank for dev)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# Application Insights (optional for local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Supabase
SUPABASE_URL=https://sevikgqyffziljftqabd.supabase.co
SUPABASE_ANON_KEY=ANON_KEY_REMOVED
SUPABASE_SERVICE_KEY=SERVICE_KEY_REMOVED
SUPABASE_JWT_SECRET=JWT_SECRET_REMOVED
